# AI Writer 环境变量配置示例
# 复制为 .env 后修改对应值

# ============ 应用配置 ============
AIWRITER_APP_NAME=AI Writer
AIWRITER_APP_VERSION=0.1.0
AIWRITER_DEBUG=false

# ============ 数据库配置 ============
# 项目数据库存储路径（{home} 会自动替换为用户主目录）
AIWRITER_DB_PATH_PATTERN={home}/.aiwriter/projects/{project_id}/project.db

# ============ LLM 配置 ============
# LLM 提供者：ollama / openai / deepseek / minimax
AIWRITER_LLM_PROVIDER=ollama

# Ollama（默认本地）
AIWRITER_LLM_BASE_URL=http://localhost:11434
AIWRITER_LLM_MODEL=qwen3:8b

# OpenAI（可选）
# AIWRITER_LLM_PROVIDER=openai
# AIWRITER_LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
# AIWRITER_LLM_BASE_URL=https://api.openai.com/v1
# AIWRITER_LLM_MODEL=gpt-4o-mini

# DeepSeek（可选）
# AIWRITER_LLM_PROVIDER=deepseek
# AIWRITER_LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
# AIWRITER_LLM_BASE_URL=https://api.deepseek.com/v1
# AIWRITER_LLM_MODEL=deepseek-chat

# MiniMax（可选）
# AIWRITER_LLM_PROVIDER=minimax
# AIWRITER_LLM_API_KEY=xxxxxxxxxxxxxxxx
# AIWRITER_LLM_BASE_URL=https://api.minimax.chat/v1
# AIWRITER_LLM_MODEL=abab6.5s-chat

# 向量嵌入模型
AIWRITER_LLM_EMBEDDING_MODEL=nomic-embed-text

# ============ ChromaDB 配置 ============
AIWRITER_CHROMA_PERSIST_DIRECTORY={home}/.aiwriter/chroma

# ============ API 配置 ============
AIWRITER_API_PREFIX=/api/v1

# 允许的 CORS 来源（开发用）
AIWRITER_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
